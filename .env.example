# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# TTS Engine: "edge-tts" (default, free) or "f5-tts" (requires GPU)
TTS_ENGINE=edge-tts

# F5-TTS Settings (only needed if TTS_ENGINE=f5-tts)
F5_MODEL=F5TTS_v1_Base
F5_REF_AUDIO=
F5_REF_TEXT=

# Video Settings
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_FPS=30
